{
  "trailingSlash": true,
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "aws.apn.bespoketraining.com" }],
      "destination": "https://www.bespoketraining.com/aws/apn/",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "aws.apn.bespoketraining.com" }],
      "destination": "https://www.bespoketraining.com/aws/apn/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/aws/apn", "destination": "/" },
    { "source": "/aws/apn/", "destination": "/" },
    { "source": "/aws/apn/apply", "destination": "/apply/" },
    { "source": "/aws/apn/apply/", "destination": "/apply/" },
    { "source": "/aws/apn/apply_schedule", "destination": "/apply_schedule/" },
    { "source": "/aws/apn/apply_schedule/", "destination": "/apply_schedule/" },
    { "source": "/aws/apn/apply_schedule_thankyou", "destination": "/apply_schedule_thankyou/" },
    { "source": "/aws/apn/apply_schedule_thankyou/", "destination": "/apply_schedule_thankyou/" },
    { "source": "/aws/apn/assets/:file*", "destination": "/assets/:file*" },
    { "source": "/aws/apn/:path*", "destination": "/:path*" }
  ]
}
